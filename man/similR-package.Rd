\name{similR-package}
\alias{similR}
\alias{similR-package}
\title{similR: local recommendation of institutional scientific literature}
\description{
Tools for preparing, versioning, validating, downloading, and using an
institutional scientific literature database. similR provides a fully local
lexical engine and an optional multilingual semantic engine managed from R
through reticulate, together with a modular local Shiny application.
}
\docType{package}
\keyword{internal}
