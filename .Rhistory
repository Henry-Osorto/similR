tfidf_test,
decreasing = TRUE
)[seq_len(min(20L, length(tfidf_test)))]
tibble::tibble(
rank = seq_along(top_tfidf),
score = tfidf_test[top_tfidf],
title = lexical_index$articles$title[top_tfidf]
)
