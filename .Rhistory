lexical_index <- similR:::load_lexical_index(
database_path = database_info()$path,
use_cache = TRUE
)
theme_index <- lexical_index$dimensions$theme
tfidf_test <- similR:::tfidf_similarity(
query_text = paste(
"alfabetización en inteligencia artificial",
"e intención emprendedora"
),
dimension_index = theme_index
)
length(tfidf_test)
range(
tfidf_test,
na.rm = TRUE
)
all(
is.finite(tfidf_test)
)
tibble::tibble(
score = tfidf_test[top_tfidf],
title = lexical_index$articles$title[
top_tfidf
]
)
top_tfidf <- order(
tfidf_test,
decreasing = TRUE
)[seq_len(min(20L, length(tfidf_test)))]
tibble::tibble(
rank = seq_along(top_tfidf),
score = tfidf_test[top_tfidf],
title = lexical_index$articles$title[top_tfidf]
)
