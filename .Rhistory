setwd('~/similR/')
# 1. Cargar Base de datos ----
setwd('~/')
# 2. Procesamiento de la Base ----
raw_data <- import_article_data("~/similR/data-raw/input/institutional_articles.csv")
processed <- process_scopus(data = raw_data,
column_map = c(title = "Title",
authors = "Authors",
abstract = "Abstract",
author_keywords = "Keywords",
doi = "DOI",
year = "Year",
source_title = "Source"),
source = "generic",
remove_duplicates = TRUE)
class(processed)
nrow(processed)
dplyr::glimpse(processed)
attr(processed, "duplicate_report")
attr(processed, "possible_duplicates")
# 3. Construcción de Dimensiones ----
processed <- build_dimension_texts(data = processed,
language = "multilingual")
# Comprobación
processed |>
dplyr::select(title,
theme_text,
purpose_text,
method_text,
data_text,
context_text) |>
dplyr::slice_head(n = 5)
dir.create(
"data-raw/cache",
recursive = TRUE,
showWarnings = FALSE
)
saveRDS(
processed,
"data-raw/cache/processed_2026-07.rds"
)
